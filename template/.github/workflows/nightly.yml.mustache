{{#ci}}
name: Swift nightly build

on:
{{#nightly}}
  schedule:
    - cron: '0 1 * * {{#every}}*{{/every}}{{^every}}1{{/every}}'
{{/nightly}}
  workflow_dispatch:

{{#count(env)}}
env:
{{#enumerated(env)}}
  {{{key}}}: {{{value}}}
{{/enumerated(env)}}
{{/count(env)}}
jobs:
{{#linux}}
  linux:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    strategy:
      matrix:
        image: ['nightly-focal', 'nightly-jammy', 'nightly-amazonlinux2']
        {{#enumerated(matrix)}}
        {{{key}}}: {{{value}}}
        {{/enumerated(matrix)}}
        {{#matrix-include}}
        {{{.}}}
        {{/matrix-include}}
    container:
      {{=<< >>=}}
      image: swiftlang/swift:${{ matrix.image }}
      <<={{ }}=>>
{{#services}}
    services:
      {{{.}}}
{{/services}}
{{#count(linux.env)}}
    env:
{{#enumerated(linux.env)}}
      {{{key}}}: {{{value}}}
{{/enumerated(linux.env)}}
{{/count(linux.env)}}
    steps:
    - name: Checkout
      uses: actions/checkout@v6
{{#additional_steps}}
    {{{.}}}
{{/additional_steps}}
{{#enable_tests}}
    - name: Test
      run: |
        swift test
{{/enable_tests}}
{{^enable_tests}}
    - name: Build
      run: |
        swift build
{{/enable_tests}}
{{/linux}}
{{/ci}}

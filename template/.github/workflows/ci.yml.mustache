{{#ci}}
name: CI

on:
  push:
    branches:
    - main
    paths:
    - '**.swift'
    - '**.yml'
  pull_request:
  workflow_dispatch:
concurrency:
{{=<< >>=}}
  group: ${{ github.workflow }}-${{ github.ref }}-ci
<<={{ }}=>>
  cancel-in-progress: true

{{#count(env)}}
env:
{{#enumerated(env)}}
  {{{key}}}: {{{value}}}
{{/enumerated(env)}}
{{/count(env)}}
jobs:
{{#mac}}
  macOS:
    runs-on: macos-14
    timeout-minutes: 15
    steps:
    - name: Checkout
      uses: actions/checkout@v4
{{#enable_tests}}
    - name: SPM tests
      run: swift test --enable-code-coverage
    - name: Convert coverage files
      run: |
        xcrun llvm-cov export -format "lcov" \
          .build/debug/{{project}}PackageTests.xctest/Contents/MacOs/{{project}}PackageTests \
          -ignore-filename-regex="\/Tests\/" \
          -ignore-filename-regex="\/Benchmarks\/" \
          -instr-profile=.build/debug/codecov/default.profdata > info.lcov
    - name: Upload to codecov.io
      uses: codecov/codecov-action@v5
      with:
        files: info.lcov
{{/enable_tests}}
{{^enable_tests}}
    - name: Build
      run: |
        swift build
{{/enable_tests}}
{{/mac}}
{{#linux}}
  linux:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    strategy:
      matrix:
        image: {{{images}}}
        {{#enumerated(matrix)}}
        {{{key}}}: {{{value}}}
        {{/enumerated(matrix)}}
        {{#matrix-include}}
        {{{.}}}
        {{/matrix-include}}
    container:
      {{=<< >>=}}
      image: ${{ matrix.image }}
      <<={{ }}=>>
{{#services}}
    services:
      {{{.}}}
{{/services}}
    steps:
    - name: Checkout
      uses: actions/checkout@v4
{{#additional_steps}}
    {{{.}}}
{{/additional_steps}}
{{#enable_tests}}
    - name: Test
      run: |
        swift test --enable-code-coverage
    - name: Convert coverage files
      run: |
        llvm-cov export -format="lcov" \
          .build/debug/{{project}}PackageTests.xctest \
          -ignore-filename-regex="\/Tests\/" \
          -ignore-filename-regex="\/Benchmarks\/" \
          -instr-profile .build/debug/codecov/default.profdata > info.lcov
    - name: Upload to codecov.io
      uses: codecov/codecov-action@v5
      with:
        files: info.lcov
{{/enable_tests}}
{{^enable_tests}}
    - name: Build
      run: |
        swift build
{{/enable_tests}}
{{/linux}}
{{#windows}}
  windows:
    runs-on: windows-latest
    strategy:
      matrix:
        swift-version: {{{swift-versions}}}
    steps:
      - uses: compnerd/gha-setup-swift@main
        with:
{{=<< >>=}}
          branch: swift-${{ matrix.swift-version }}-release
          tag: ${{ matrix.swift-version }}-RELEASE
<<={{ }}=>>
      - uses: actions/checkout@v4
{{#enable_tests}}
      - run: swift test
{{/enable_tests}}      
{{^enable_tests}}
      - run: swift build
{{/enable_tests}}      
{{/windows}}
{{/ci}}

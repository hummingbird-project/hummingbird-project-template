{{#ci}}
name: CI

on:
  push:
    branches:
    - main
    paths:
    - '**.swift'
    - '**.yml'
  pull_request:
  workflow_dispatch:
concurrency:
{{=<< >>=}}
  group: ${{ github.workflow }}-${{ github.ref }}-ci
<<={{ }}=>>
  cancel-in-progress: true

permissions:
  contents: read

{{#count(env)}}
env:
{{#enumerated(env)}}
  {{{key}}}: {{{value}}}
{{/enumerated(env)}}
{{/count(env)}}
jobs:
{{#mac}}
  macOS:
    runs-on: macos-26
    timeout-minutes: 15
{{#count(mac.env)}}
    env:
{{#enumerated(mac.env)}}
      {{{key}}}: {{{value}}}
{{/enumerated(mac.env)}}
{{/count(mac.env)}}
    steps:
    - name: Select appropriate Xcode version
      uses: maxim-lobanov/setup-xcode@ed7a3b1fda3918c0306d1b724322adc0b8cc0a90 # v1.7.0
      with:
        xcode-version: latest-stable
    - name: Checkout
      uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd #v6.0.2
{{#enable_tests}}
    - name: SPM tests
      run: swift test --enable-code-coverage
    - name: Convert coverage files
      run: |
        xcrun llvm-cov export -format "lcov" \
          .build/debug/{{project}}PackageTests.xctest/Contents/MacOs/{{project}}PackageTests \
          -ignore-filename-regex="\/Tests\/" \
          -ignore-filename-regex="\/Benchmarks\/" \
          -instr-profile=.build/debug/codecov/default.profdata > info.lcov
    - name: Upload to codecov.io
      uses: codecov/codecov-action@b9fd7d16f6d7d1b5d2bec1a2887e65ceed900238 #v4.6.0
      with:
        files: info.lcov
{{=<< >>=}}
        token: ${{ secrets.CODECOV_TOKEN }}
<<={{ }}=>>
{{/enable_tests}}
{{^enable_tests}}
    - name: Build
      run: |
        swift build
{{/enable_tests}}

{{/mac}}
{{#linux}}
  linux:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    strategy:
      matrix:
        image: {{{images}}}
        {{#enumerated(matrix)}}
        {{{key}}}: {{{value}}}
        {{/enumerated(matrix)}}
        {{#matrix-include}}
        {{{.}}}
        {{/matrix-include}}
    container:
      {{=<< >>=}}
      image: ${{ matrix.image }}
      <<={{ }}=>>
{{#services}}
    services:
      {{{.}}}
{{/services}}
{{#count(linux.env)}}
    env:
{{#enumerated(linux.env)}}
      {{{key}}}: {{{value}}}
{{/enumerated(linux.env)}}
{{/count(linux.env)}}
    steps:
    - name: Checkout
      uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd #v6.0.2
{{#additional_steps}}
    {{{.}}}
{{/additional_steps}}
{{#enable_tests}}
    - name: Test
      run: |
        swift test --enable-code-coverage
    - name: Convert coverage files
      run: |
        llvm-cov export -format="lcov" \
          .build/debug/{{project}}PackageTests.xctest \
          -ignore-filename-regex="\/Tests\/" \
          -ignore-filename-regex="\/Benchmarks\/" \
          -instr-profile .build/debug/codecov/default.profdata > info.lcov
    - name: Upload to codecov.io
      uses: codecov/codecov-action@b9fd7d16f6d7d1b5d2bec1a2887e65ceed900238 #v4.6.0
      with:
        files: info.lcov
{{=<< >>=}}
        token: ${{ secrets.CODECOV_TOKEN }}
<<={{ }}=>>
{{/enable_tests}}
{{^enable_tests}}
    - name: Build
      run: |
        swift build
{{/enable_tests}}
{{/linux}}
{{#windows}}
  windows:
    runs-on: windows-latest
    strategy:
      matrix:
        swift-version: {{{swift-versions}}}
    steps:
      - uses: compnerd/gha-setup-swift@eeda069c5bc95ac8a9ac5cea7d4f588ae5420ca5 # v0.4.0
        with:
{{=<< >>=}}
          branch: swift-${{ matrix.swift-version }}-release
          tag: ${{ matrix.swift-version }}-RELEASE
<<={{ }}=>>
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd #v6.0.2
{{#enable_tests}}
      - run: swift test
{{/enable_tests}}      
{{^enable_tests}}
      - run: swift build
{{/enable_tests}}      
{{/windows}}
{{/ci}}
